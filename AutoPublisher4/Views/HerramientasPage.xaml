<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AutoPublisher4.Views.HerramientasPage"
    Title="Herramientas">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid
            Grid.Row="0"
            BackgroundColor="{StaticResource Primary}"
            Padding="16,48,16,16">
            <Label
                Text="Herramientas"
                TextColor="White"
                FontSize="22"
                FontAttributes="Bold" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Sección: Datos -->
                <Label Text="Datos" FontSize="13" TextColor="{StaticResource Gray400}" Margin="0,4,0,0" />

                <Border
                    Stroke="{StaticResource Gray100}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="📥" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Importar publicaciones" FontSize="14" />
                                <Label Text="Desde archivo CSV o JSON" FontSize="12" TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="0.5" Color="{StaticResource Gray100}" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="📤" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Exportar publicaciones" FontSize="14" />
                                <Label Text="Guardar como CSV o JSON" FontSize="12" TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Sección: Mantenimiento -->
                <Label Text="Mantenimiento" FontSize="13" TextColor="{StaticResource Gray400}" Margin="0,8,0,0" />

                <Border
                    Stroke="{StaticResource Gray100}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="🗃️" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Limpiar caché" FontSize="14" />
                                <Label Text="Eliminar archivos temporales" FontSize="12" TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="0.5" Color="{StaticResource Gray100}" Margin="16,0" />
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="📊" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Estadísticas" FontSize="14" />
                                <Label Text="Resumen de envíos y resultados" FontSize="12" TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
