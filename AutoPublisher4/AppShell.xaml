<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AutoPublisher4.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AutoPublisher4.Views"
    Title="AutoPublisher4"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <Tab Title="Publicación" Icon="tab_publicacion.png">
            <ShellContent
                Title="Publicación"
                ContentTemplate="{DataTemplate views:PublicacionPage}"
                Route="PublicacionPage" />
        </Tab>

        <Tab Title="Publicar" Icon="tab_publicar.png">
            <ShellContent
                Title="Publicar"
                ContentTemplate="{DataTemplate views:PublicarPage}"
                Route="PublicarPage" />
        </Tab>

        <Tab Title="Cuentas" Icon="tab_cuentas.png">
            <ShellContent
                Title="Cuentas de correo"
                ContentTemplate="{DataTemplate views:CuentasCorreoPage}"
                Route="CuentasCorreoPage" />
        </Tab>

        <Tab Title="Herramientas" Icon="tab_herramientas.png">
            <ShellContent
                Title="Herramientas"
                ContentTemplate="{DataTemplate views:HerramientasPage}"
                Route="HerramientasPage" />
        </Tab>

        <Tab Title="Configuración" Icon="tab_configuracion.png">
            <ShellContent
                Title="Configuración"
                ContentTemplate="{DataTemplate views:ConfiguracionPage}"
                Route="ConfiguracionPage" />
        </Tab>
    </TabBar>

</Shell>
